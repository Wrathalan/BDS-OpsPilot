{
  "name": "opspilot-rmm",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/run-private-cli.mjs next dev --hostname 127.0.0.1",
    "local": "npm run setup && npm run dev",
    "build": "node scripts/run-private-cli.mjs next build",
    "start": "node scripts/run-private-cli.mjs next start --hostname 0.0.0.0",
    "setup": "node scripts/run-private-cli.mjs prisma generate && npm run db:sync",
    "db:migrate": "node scripts/run-private-cli.mjs prisma migrate dev",
    "db:generate": "node scripts/run-private-cli.mjs prisma generate",
    "db:prepare": "node prisma/prepare-database.mjs",
    "db:sync": "npm run db:prepare && node scripts/run-private-cli.mjs prisma db push --skip-generate && npm run db:bootstrap",
    "db:bootstrap": "node prisma/bootstrap.mjs",
    "backup": "node scripts/create-backup.mjs",
    "agent:build:windows": "node scripts/build-agent-windows.mjs",
    "docker:up": "docker compose up --build -d --remove-orphans",
    "docker:down": "docker compose down --remove-orphans",
    "docker:logs": "docker compose logs -f opspilot",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:e2e:reset": "node scripts/reset-e2e-database.mjs",
    "test:e2e:windows-agent": "npm run agent:build:windows && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern playwright-report --ignore-pattern test-results",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "prisma": "^6.19.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "type": "module"
}
